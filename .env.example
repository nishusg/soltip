# Backend API URL (e.g. http://localhost:3001/api for local development)
VITE_API_URL=

# Solana Smart Contract Program ID
VITE_PROGRAM_ID=

# Platform Treasury Wallet Address for receiving fee splits
VITE_PLATFORM_WALLET=

# Solana RPC node endpoint (e.g. devnet, mainnet-beta, or local validator)
VITE_SOLANA_RPC_URL=

# Branding Site Name (e.g. SolTip)
VITE_SITE_NAME=

# Frontend Website URL (e.g. http://localhost:5173 for local development)
VITE_SITE_URL=

# Platform transaction fee percentage (flat rate, e.g. 5 for 5%)
VITE_PLATFORM_FEE=

